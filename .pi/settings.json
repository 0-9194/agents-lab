{
  "packages": [
    "../packages/pi-stack",
    "../packages/git-skills",
    "../packages/web-skills",
    "../packages/pi-skills",
    "../packages/lab-skills"
  ],
  "piStack": {
    "monitorProviderPatch": {
      "classifierThinking": "off",
      "classifierModelByProvider": {
        "github-copilot": "github-copilot/claude-haiku-4.5",
        "openai-codex": "openai-codex/gpt-5.4-mini"
      },
      "hedgeConversationHistory": false
    },
    "colonyPilot": {
      "preflight": {
        "enabled": true,
        "enforceOnAntColonyTool": true,
        "requiredExecutables": [
          "node",
          "git"
        ]
      },
      "budgetPolicy": {
        "enabled": true,
        "enforceOnAntColonyTool": true,
        "requireMaxCost": true,
        "autoInjectMaxCost": true,
        "defaultMaxCostUsd": 2,
        "hardCapUsd": 20,
        "minMaxCostUsd": 0.05,
        "enforceProviderBudgetBlock": true,
        "providerBudgetLookbackDays": 30,
        "allowProviderBudgetOverride": true,
        "providerBudgetOverrideToken": "budget-override:"
      },
      "projectTaskSync": {
        "enabled": true,
        "createOnLaunch": true,
        "trackProgress": true,
        "markTerminalState": true,
        "taskIdPrefix": "colony",
        "requireHumanClose": true,
        "maxNoteLines": 20
      },
      "deliveryPolicy": {
        "enabled": true,
        "mode": "patch-artifact",
        "requireWorkspaceReport": true,
        "requireTaskSummary": true,
        "requireFileInventory": true,
        "requireValidationCommandLog": true,
        "blockOnMissingEvidence": true
      }
    },
    "guardrailsCore": {
      "providerBudgetGovernor": {
        "enabled": true,
        "lookbackDays": 30,
        "allowOverride": true,
        "overrideToken": "budget-override:",
        "recoveryCommands": [
          "doctor",
          "quota-visibility",
          "model",
          "login"
        ]
      }
    },
    "quotaVisibility": {
      "defaultDays": 30,
      "monthlyQuotaRequests": 1000,
      "providerBudgets": {
        "github-copilot": {
          "owner": "shared-github-account",
          "period": "monthly",
          "unit": "requests",
          "requestSharePolicy": "remaining",
          "shareMonthlyRequestsPct": 50,
          "monthlyQuotaCostUsd": 40,
          "warnPct": 80,
          "hardPct": 100
        }
      }
    }
  }
}
