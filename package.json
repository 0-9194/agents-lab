{
  "name": "agents-lab",
  "private": true,
  "description": "Monorepo — solo de curadoria e experimentação para o ecossistema pi",
  "workspaces": [
    "packages/*"
  ],
  "scripts": {
    "list": "npm ls --workspaces --depth=0",
    "test": "node --test packages/*/test/*.test.mjs",
    "verify": "node scripts/verify-pi-stack.mjs",
    "release": "changeset version",
    "publish:all": "npm run build --workspaces --if-present && changeset publish"
  },
  "devDependencies": {
    "@changesets/cli": "^2.30.0"
  },
  "engines": {
    "node": ">=22"
  }
}
